{
  "name": "hookdump",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source webhook debugger. Receive, inspect, and replay webhooks.",
  "homepage": "https://hookdump.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orangekame3/hookdump.git"
  },
  "bugs": {
    "url": "https://github.com/orangekame3/hookdump/issues"
  },
  "author": "orangekame3",
  "license": "MIT",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w backend --host",
    "dev:frontend": "npm run dev -w frontend --host",
    "build": "npm run build -w shared && npm run build -w backend && npm run build -w frontend",
    "start": "npm run start -w backend"
  },
  "keywords": [
    "webhook",
    "debugging",
    "replay",
    "self-hosted",
    "open-source",
    "requestbin-alternative"
  ]
}
