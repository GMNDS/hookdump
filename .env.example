# Cloudflare Tunnel token (required for tunnel profile)
# Get this from: Cloudflare Zero Trust > Access > Tunnels > Create > Copy token
TUNNEL_TOKEN=your_tunnel_token_here

# Demo mode (for hookdump.dev demo site)
# Shows demo banner and disables some features
DEMO_MODE=false

# SendGrid API key (optional, for monitor email alerts)
# Get this from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxx
EMAIL_FROM=alerts@hookdump.dev
